    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/static": "^1.4.10",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
