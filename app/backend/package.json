{
  "name": "@curator/backend",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile ../../curator-server",
    "test": "bun test",
    "lint": "bunx biome lint .",
    "check": "bunx biome check .",
    "typecheck": "tsc --noEmit",
