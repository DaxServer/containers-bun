  },
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "dev": "concurrently --pad-prefix --names backend,frontend --prefix-colors cyan,magenta \"bun --cwd backend dev\" \"bun --cwd frontend dev\"",
    "build": "bun --filter @curator/backend build",
    "test": "bun test",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint",
    "format": "bun --filter '*' format",
    "db:generate": "bun --filter @curator/backend db:generate",
    "db:migrate": "bun --filter @curator/backend db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
